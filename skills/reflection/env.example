# Copy to .env and fill in values.

# Provider API keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: OpenAI base URL (e.g., for compatible endpoints)
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL_ID=
ANTHROPIC_MODEL_ID=
OPENAI_CHAT_MODEL_ID=

# Provider assignment strategy (fixed | random | shuffle)
REFLECTION_PROVIDER_STRATEGY=fixed
# REFLECTION_PROVIDER_MODE=
# REFLECTION_RANDOM_PROVIDERS=false
# REFLECTION_SHUFFLE_PROVIDERS=false

# Role-specific overrides
REFLECTION_GENERATOR_PROVIDER=
REFLECTION_GENERATOR_MODEL=
REFLECTION_GENERATOR_API_KEY=
REFLECTION_GENERATOR_BASE_URL=
REFLECTION_GENERATOR_TEMPERATURE=

REFLECTION_CRITIC_PROVIDER=
REFLECTION_CRITIC_MODEL=
REFLECTION_CRITIC_API_KEY=
REFLECTION_CRITIC_BASE_URL=
REFLECTION_CRITIC_TEMPERATURE=

REFLECTION_REFINER_PROVIDER=
REFLECTION_REFINER_MODEL=
REFLECTION_REFINER_API_KEY=
REFLECTION_REFINER_BASE_URL=
REFLECTION_REFINER_TEMPERATURE=

# Global temperature override
REFLECTION_TEMPERATURE=
LLM_TEMPERATURE=

# Optional: config file path
CONFIG_FILE=
