# Copy to .env and fill in values.

# Provider API keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: OpenAI base URL (e.g., for compatible endpoints)
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL_ID=
ANTHROPIC_MODEL_ID=
OPENAI_CHAT_MODEL_ID=

# Provider assignment strategy (fixed | random | shuffle)
REFLECTION_PROVIDER_STRATEGY=fixed
# REFLECTION_PROVIDER_MODE=
# REFLECTION_RANDOM_PROVIDERS=false
# REFLECTION_SHUFFLE_PROVIDERS=false

# Role-specific overrides
REFLECTION_DECOMPOSER_PROVIDER=
REFLECTION_DECOMPOSER_MODEL=
REFLECTION_DECOMPOSER_API_KEY=
REFLECTION_DECOMPOSER_BASE_URL=
REFLECTION_DECOMPOSER_TEMPERATURE=
REFLECTION_DECOMPOSER_TIMEOUT=

REFLECTION_SOLVER_PROVIDER=
REFLECTION_SOLVER_MODEL=
REFLECTION_SOLVER_API_KEY=
REFLECTION_SOLVER_BASE_URL=
REFLECTION_SOLVER_TEMPERATURE=
REFLECTION_SOLVER_TIMEOUT=

REFLECTION_VERIFIER_PROVIDER=
REFLECTION_VERIFIER_MODEL=
REFLECTION_VERIFIER_API_KEY=
REFLECTION_VERIFIER_BASE_URL=
REFLECTION_VERIFIER_TEMPERATURE=
REFLECTION_VERIFIER_TIMEOUT=

REFLECTION_INTEGRATOR_PROVIDER=
REFLECTION_INTEGRATOR_MODEL=
REFLECTION_INTEGRATOR_API_KEY=
REFLECTION_INTEGRATOR_BASE_URL=
REFLECTION_INTEGRATOR_TEMPERATURE=
REFLECTION_INTEGRATOR_TIMEOUT=

REFLECTION_REFLECTOR_PROVIDER=
REFLECTION_REFLECTOR_MODEL=
REFLECTION_REFLECTOR_API_KEY=
REFLECTION_REFLECTOR_BASE_URL=
REFLECTION_REFLECTOR_TEMPERATURE=
REFLECTION_REFLECTOR_TIMEOUT=

# Global overrides
REFLECTION_TEMPERATURE=
REFLECTION_TIMEOUT=
REFLECTION_OUTPUT_SCHEMA=nested
LLM_TEMPERATURE=
LLM_TIMEOUT_SEC=

# Optional: config file path
CONFIG_FILE=
