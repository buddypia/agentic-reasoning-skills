# ===========================================
# Multi-LLM Reflection Pattern Configuration (5段階)
# リフレクションパターン マルチエージェント設定
# ===========================================
#
# 設定の優先順位 (高い順):
#   1. CLI引数 (--decomposer-model, etc.)
#   2. 環境変数 (このファイル)
#   3. 設定ファイル (config.yaml)
#   4. デフォルト値
#
# ===========================================

# ===========================================
# APIキー (必須)
# ===========================================

# Gemini API (Decomposer / Solver)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic API (Verifier)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (Integrator / Reflector)
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # Azure OpenAIなどを使用する場合

# ===========================================
# プロバイダー固有のモデルID (オプション)
# ===========================================

# GEMINI_MODEL_ID=gemini-3-pro-preview
# ANTHROPIC_MODEL_ID=claude-opus-4-1-20250805
# OPENAI_CHAT_MODEL_ID=gpt-5.2

# ===========================================
# エージェント別設定 (オプション)
# REFLECTION_<ROLE>_<KEY> 形式
# ===========================================

# [Decomposer (分解)]
# REFLECTION_DECOMPOSER_PROVIDER=gemini
# REFLECTION_DECOMPOSER_MODEL=gemini-3-pro-preview
# REFLECTION_DECOMPOSER_API_KEY=your_key_here  # GEMINI_API_KEYより優先
# REFLECTION_DECOMPOSER_TEMPERATURE=0.7
# REFLECTION_DECOMPOSER_TIMEOUT=120

# [Solver (解決)]
# REFLECTION_SOLVER_PROVIDER=gemini
# REFLECTION_SOLVER_MODEL=gemini-3-pro-preview
# REFLECTION_SOLVER_API_KEY=your_key_here  # GEMINI_API_KEYより優先
# REFLECTION_SOLVER_TEMPERATURE=0.7
# REFLECTION_SOLVER_TIMEOUT=120

# [Verifier (検証)]
# REFLECTION_VERIFIER_PROVIDER=anthropic
# REFLECTION_VERIFIER_MODEL=claude-opus-4-1-20250805
# REFLECTION_VERIFIER_API_KEY=your_key_here  # ANTHROPIC_API_KEYより優先
# REFLECTION_VERIFIER_TEMPERATURE=0.7
# REFLECTION_VERIFIER_TIMEOUT=120

# [Integrator (統合)]
# REFLECTION_INTEGRATOR_PROVIDER=openai
# REFLECTION_INTEGRATOR_MODEL=gpt-5.2
# REFLECTION_INTEGRATOR_API_KEY=your_key_here  # OPENAI_API_KEYより優先
# REFLECTION_INTEGRATOR_BASE_URL=https://api.openai.com/v1
# REFLECTION_INTEGRATOR_TEMPERATURE=0.7
# REFLECTION_INTEGRATOR_TIMEOUT=120

# [Reflector (反省)]
# REFLECTION_REFLECTOR_PROVIDER=openai
# REFLECTION_REFLECTOR_MODEL=gpt-5.2
# REFLECTION_REFLECTOR_API_KEY=your_key_here  # OPENAI_API_KEYより優先
# REFLECTION_REFLECTOR_BASE_URL=https://api.openai.com/v1
# REFLECTION_REFLECTOR_TEMPERATURE=0.7
# REFLECTION_REFLECTOR_TIMEOUT=120

# ===========================================
# 共通パラメータ (オプション)
# ===========================================

# 全エージェントのTemperature（デフォルト: 0.7）
# REFLECTION_TEMPERATURE=0.7
# LLM_TEMPERATURE=0.7  # 後方互換

# エージェントごとのタイムアウト秒数（デフォルト: 120）
# REFLECTION_TIMEOUT=120
# LLM_TIMEOUT_SEC=120  # 後方互換

# ===========================================
# DevUI設定
# ===========================================

# DevUIサーバーのポート番号（デフォルト: 8095）
# REFLECTION_DEVUI_PORT=8095
# DEVUI_PORT=8095  # 後方互換

# ===========================================
# 設定ファイルのパス（オプション）
# ===========================================

# YAML/JSON設定ファイルを使用する場合に指定
# CONFIG_FILE=config.yaml

# ===========================================
# デフォルト値
# ===========================================
# Decomposer: gemini / gemini-3-pro-preview
# Solver:    gemini / gemini-3-pro-preview
# Verifier:  anthropic / claude-opus-4-1-20250805
# Integrator: openai / gpt-5.2
# Reflector:  openai / gpt-5.2
#
# 設定詳細を確認: python main.py --show-config
