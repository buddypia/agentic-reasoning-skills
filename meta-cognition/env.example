# Copy to .env and fill in values.

# Provider API keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: OpenAI base URL (e.g., for compatible endpoints)
OPENAI_BASE_URL=

# Optional model overrides
GEMINI_MODEL_ID=
ANTHROPIC_MODEL_ID=
OPENAI_CHAT_MODEL_ID=

# Provider assignment strategy (fixed | random | shuffle)
METACOGNITION_PROVIDER_STRATEGY=fixed
# METACOGNITION_PROVIDER_MODE=
# METACOGNITION_RANDOM_PROVIDERS=false
# METACOGNITION_SHUFFLE_PROVIDERS=false

# Role-specific overrides
METACOGNITION_DECOMPOSER_PROVIDER=
METACOGNITION_DECOMPOSER_MODEL=
METACOGNITION_DECOMPOSER_API_KEY=
METACOGNITION_DECOMPOSER_BASE_URL=
METACOGNITION_DECOMPOSER_TEMPERATURE=
METACOGNITION_DECOMPOSER_TIMEOUT=

METACOGNITION_SOLVER_PROVIDER=
METACOGNITION_SOLVER_MODEL=
METACOGNITION_SOLVER_API_KEY=
METACOGNITION_SOLVER_BASE_URL=
METACOGNITION_SOLVER_TEMPERATURE=
METACOGNITION_SOLVER_TIMEOUT=

METACOGNITION_VERIFIER_PROVIDER=
METACOGNITION_VERIFIER_MODEL=
METACOGNITION_VERIFIER_API_KEY=
METACOGNITION_VERIFIER_BASE_URL=
METACOGNITION_VERIFIER_TEMPERATURE=
METACOGNITION_VERIFIER_TIMEOUT=

METACOGNITION_INTEGRATOR_PROVIDER=
METACOGNITION_INTEGRATOR_MODEL=
METACOGNITION_INTEGRATOR_API_KEY=
METACOGNITION_INTEGRATOR_BASE_URL=
METACOGNITION_INTEGRATOR_TEMPERATURE=
METACOGNITION_INTEGRATOR_TIMEOUT=

METACOGNITION_REFLECTOR_PROVIDER=
METACOGNITION_REFLECTOR_MODEL=
METACOGNITION_REFLECTOR_API_KEY=
METACOGNITION_REFLECTOR_BASE_URL=
METACOGNITION_REFLECTOR_TEMPERATURE=
METACOGNITION_REFLECTOR_TIMEOUT=

# Global overrides
METACOGNITION_TEMPERATURE=
METACOGNITION_TIMEOUT=
METACOGNITION_OUTPUT_SCHEMA=nested
LLM_TEMPERATURE=
LLM_TIMEOUT_SEC=

# Optional: config file path
CONFIG_FILE=
